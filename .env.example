# ============================================================
# Qyvera AI - Environment Configuration
# ============================================================
# Puter API is used for all AI model access.
# No API keys are needed — Puter handles authentication client-side.
# Simply deploy and users can start chatting immediately.
# ============================================================

# ---- Optional Settings ----

# Access code for password protection (comma-separated for multiple)
# ACCESS_CODE=qyvera-access-code

# App URL (used for metadata)
# APP_URL=https://qyvera.web.app
